# Application Settings
NODE_ENV=development
PORT=3000
API_PORT=8000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/website_intelligence
REDIS_URL=redis://localhost:6379

# Vector Store Configuration
VECTOR_STORE_TYPE=chromadb # Options: chromadb, pinecone, qdrant, weaviate
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment
PINECONE_INDEX_NAME=website-memory

# AI/LLM Configuration
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
LLM_PROVIDER=openai # Options: openai, anthropic
LLM_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# Crawler Configuration
MAX_CRAWL_DEPTH=5
CRAWL_TIMEOUT=30000
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
USER_AGENT=WebsiteIntelligencePlatform/1.0
RESPECT_ROBOTS_TXT=true

# Authentication
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE_HOURS=24
API_KEY_SALT=your_api_key_salt

# Webhook Configuration
WEBHOOK_SECRET=your_webhook_secret
CI_CD_WEBHOOK_ENDPOINT=/api/webhooks/deployment

# Scheduler Configuration
ENABLE_SCHEDULER=true
GLOBAL_CRAWL_SCHEDULE=0 2 * * * # Daily at 2 AM
CLIENT_CRAWL_SCHEDULE=0 */6 * * * # Every 6 hours

# Storage
STORAGE_PATH=./data
SCREENSHOTS_PATH=./data/screenshots
CRAWL_LOGS_PATH=./data/logs

# Feature Flags
ENABLE_CHANGE_DETECTION=true
ENABLE_INCREMENTAL_CRAWL=true
ENABLE_LLM_SUMMARIZATION=true
ENABLE_VECTOR_SEARCH=true

# Performance
MAX_CONCURRENT_CRAWLS=5
BATCH_SIZE=10
EMBEDDING_BATCH_SIZE=100

# Monitoring
ENABLE_MONITORING=true
PROMETHEUS_PORT=9090
LOG_LEVEL=info